variable "account" {
  description = "AWS account name"
  type        = string
  default     = "aws-sudoblark-development"
}

variable "project" {
  description = "Project name"
  type        = string
  default     = "bookshelf"
}

variable "application" {
  description = "Application name"
  type        = string
  default     = "demo"
}
